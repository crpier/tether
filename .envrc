# Use the host's uv project + its venv from anywhere under the repo root.
export UV_PROJECT="$PWD/apps/host"          # `uv run/sync` in root target apps/host
export VIRTUAL_ENV="$PWD/apps/host/.venv"   # activate it for direct `python`
PATH_add "$VIRTUAL_ENV/bin"

# web tooling (vite/tsc/eslint) resolvable from root
PATH_add "$PWD/apps/web/node_modules/.bin"
