# Production `.env` template for the VM deploy (docs/deployment.md).
#
# Copy to `/srv/tether/.env` (next to `compose.yaml`) and fill in real values —
# assembled by hand from 1Password (source of truth), never committed.
# `deploy/restic.env.example` is separate: it's read by the backup timer, not by
# the app container.
#
# This mirrors the repo-root `.env.example` (used by `just bootstrap` for local
# dev) with production-only defaults: TETHER_SECURE_COOKIES=true and an absolute
# TETHER_PI_AGENT_DIR outside any git worktree. `TETHER_DATABASE_PATH`,
# `TETHER_KB_ROOT`, and `FASTEMBED_CACHE_PATH` are NOT set here — compose.yaml
# pins those to the `data`/`model-cache` volumes for every environment.

# --- Image tag (optional) ----------------------------------------------------
# Which published GHCR tag `docker compose up` runs. `just deploy` (from your
# laptop) pushes `:<git-sha>` and moves `:latest` to it. Pin to a sha to roll
# back (docs/deployment.md#rollback); unset/latest tracks the newest push.
# TETHER_IMAGE_TAG=latest

# --- Auth (required) --------------------------------------------------------
# App login password and the session-cookie signing secret. Generate strong
# values, e.g.  python -c "import secrets; print(secrets.token_urlsafe(32))"
TETHER_APP_PASSWORD=change-me
TETHER_SESSION_SECRET=change-me

# --- Speech-to-text (required) -----------------------------------------------
# STT is an always-on host dependency (ADR 0018): the host fails fast at boot
# if this is unset. Points at any OpenAI-compatible transcription endpoint
# (OpenAI, Groq, a self-hosted server) by base URL.
TETHER_STT_API_KEY=change-me
# TETHER_STT_BASE_URL=https://api.openai.com/v1
# TETHER_STT_MODEL=whisper-1

# --- Cookies ----------------------------------------------------------------
# Secure cookies require HTTPS. The VM is only ever reached over Tailscale
# HTTPS (`tailscale serve`), so this MUST be true here (unlike the local
# repo-root `.env.example`, which defaults it false for plain http://localhost).
TETHER_SECURE_COOKIES=true

# --- Agent model (required for chat / scheduled-prompt triggers) ------------
# The default model id and the allowlist the UI offers. The allowlist is JSON;
# `id` is selected by `TETHER_DEFAULT_MODEL`. Provider credentials do not live
# in this file; pi reads them from ${TETHER_PI_AGENT_DIR}/auth.json (see below —
# authorize it once, from a laptop, over `ssh -L` or by copying the file).
# The allowlist MUST stay single-quoted: dotenv-style parsers strip embedded
# double quotes from an unquoted value, which would corrupt the JSON.
TETHER_DEFAULT_MODEL=gpt-5.6-luna
TETHER_MODEL_ALLOWLIST='[{"display_name":"GPT-5.6 Terra","id":"gpt-5.6-terra","model_id":"gpt-5.6-terra","provider":"openai-codex","thinking_level":"medium"},{"display_name":"GPT-5.6 Luna","id":"gpt-5.6-luna","model_id":"gpt-5.6-luna","provider":"openai-codex","thinking_level":"off"}]'

# --- pi provider credentials -------------------------------------------------
# Mounted into the container as /pi-agent and used as PI_CODING_AGENT_DIR. This
# is durable secret state (Codex OAuth tokens, OpenCode Go API key). Point it at
# a directory under the app dir (backed up alongside `data`/`model-cache` — see
# deploy/backup.sh) and authorize it once:
#   mkdir -p /srv/tether/pi-agent && chmod 700 /srv/tether/pi-agent
#   PI_CODING_AGENT_DIR=/srv/tether/pi-agent /srv/tether/apps/agent/node_modules/.bin/pi
#   /login openai-codex
# The container runs as root, so refreshed OAuth files may become root-owned.
TETHER_PI_AGENT_DIR=/srv/tether/pi-agent

# --- Optional ingestion gates (YouTube / Gmail / Readwise / kosync) ---------
# All off by default and safe to leave unset. Copy the relevant block from the
# repo-root `.env.example` if/when you turn one on in production; see
# docs/deployment.md and docs/development.md for the setup steps.
