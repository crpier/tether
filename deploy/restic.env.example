# Backup credentials for `deploy/backup.sh`, loaded by the `tether-backup`
# systemd unit (`EnvironmentFile=/srv/tether/restic.env`) — separate from the
# app's `.env` so backup secrets are never handed to the app container.
# Copy to `/srv/tether/restic.env`, `chmod 600`, fill from 1Password (source of
# truth for the restic passphrase — it must never live *only* on the VM: if
# this file is lost with no copy elsewhere, the B2 backup is unrecoverable).

# --- Restic repository (Backblaze B2, client-side encrypted) ----------------
# B2 application key scoped to a single bucket dedicated to Tether backups.
RESTIC_REPOSITORY=b2:tether-backups:restic
B2_ACCOUNT_ID=change-me
B2_ACCOUNT_KEY=change-me

# Repository encryption passphrase. Generate once, store in 1Password, never
# rotate without re-keying the repo (`restic key add` / `restic key remove`).
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
RESTIC_PASSWORD=change-me

# --- Dead-man's-switch --------------------------------------------------
# healthchecks.io check UUID. backup.sh pings /start on launch, the bare URL on
# success, and /fail on any error (via a trap) — so both a failed run and a run
# that never happens (VM down, timer disabled) alert.
HEALTHCHECKS_PING_URL=https://hc-ping.com/change-me

# --- What to back up ----------------------------------------------------
# Paths on the VM host (not inside the container) that hold the docker named
# volumes and the app checkout. Defaults match docs/deployment.md's layout;
# override only if you deployed somewhere else.
# TETHER_APP_DIR=/srv/tether
