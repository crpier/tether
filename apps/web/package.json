{
  "name": "@tether/web",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "codegen": "openapi-typescript ../../openapi.json -o src/generated/schema.ts && node scripts/generate-client.mjs",
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:generated": "prettier --write src/generated",
    "lint": "eslint .",
    "serve": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.0",
    "solid-devtools": "^0.34.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.1.4",
    "vite-plugin-solid": "2.11.9",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@tanstack/solid-query": "^5.101.1",
    "cva": "1.0.0-beta.4",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "openapi-fetch": "^0.17.0",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.6.0",
    "vega-embed": "^7.1.0"
  }
