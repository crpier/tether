{
  "tools": [
    {
      "endpoint": "/internal/tools/capture",
      "name": "capture",
      "params_model": "CaptureParams",
      "schema": {
        "$defs": {
          "MemoryContent": {
            "minLength": 1,
            "type": "string"
          }
        },
        "description": "Params for capturing a loose Memory.",
        "properties": {
          "content": {
            "$ref": "#/$defs/MemoryContent"
          },
          "facets": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Facets"
          }
        },
        "required": ["content"],
        "title": "CaptureParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/browse",
      "name": "browse",
      "params_model": "BrowseParams",
      "schema": {
        "$defs": {
          "MemoryState": {
            "enum": ["loose", "tethered"],
            "type": "string"
          }
        },
        "description": "Params for the review queue (`loose`) / corpus browse (`tethered`).",
        "properties": {
          "state": {
            "$ref": "#/$defs/MemoryState"
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "required": ["state"],
        "title": "BrowseParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/search",
      "name": "search",
      "params_model": "SearchParams",
      "schema": {
        "$defs": {
          "SourceType": {
            "enum": ["memory", "bucket_item"],
            "type": "string"
          }
        },
        "description": "Params for the assistant's cross-source Search (Memories + Bucket items).\n\n`facets`, when supplied, is an exact-match AND filter applied to the\nMemory arm only: a Memory must carry every given key with exactly that\nvalue to be returned. `sources`, when supplied, restricts fusion to that\nsubset of arms; omitted, every arm runs. `after`/`before`, when supplied,\nbound every arm's own capture timestamp (a Memory's `tethered_at`, a\nBucket item's `created_at`), inclusive on both ends; either or both may\nbe given, and supplying `after` later than `before` is rejected.",
        "properties": {
          "q": {
            "title": "Q",
            "type": "string"
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          },
          "facets": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Facets"
          },
          "sources": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/$defs/SourceType"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Sources"
          },
          "after": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "After"
          },
          "before": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Before"
          }
        },
        "required": ["q"],
        "title": "SearchParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/review_digest",
      "name": "review_digest",
      "params_model": "ReviewDigestParams",
      "schema": {
        "description": "Params for the AI-assisted Review digest.\n\nThe digest is computed over the whole live queue, so it takes no inputs\nbeyond the session identity the gate already requires.",
        "properties": {},
        "title": "ReviewDigestParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/tether",
      "name": "tether",
      "params_model": "TetherParams",
      "schema": {
        "description": "Params for promoting a loose Memory to tethered.",
        "properties": {
          "memory_id": {
            "format": "uuid7",
            "title": "Memory Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["memory_id", "version"],
        "title": "TetherParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/edit",
      "name": "edit",
      "params_model": "EditParams",
      "schema": {
        "$defs": {
          "MemoryContent": {
            "minLength": 1,
            "type": "string"
          }
        },
        "description": "Params for editing a Memory's content at an observed version.\n\n`facets`, when supplied, replaces the stored Commons facet set verbatim\n(an empty object clears it); omitted, facets stay unchanged.",
        "properties": {
          "memory_id": {
            "format": "uuid7",
            "title": "Memory Id",
            "type": "string"
          },
          "content": {
            "$ref": "#/$defs/MemoryContent"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          },
          "facets": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Facets"
          }
        },
        "required": ["memory_id", "content", "version"],
        "title": "EditParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/reject",
      "name": "reject",
      "params_model": "RejectParams",
      "schema": {
        "description": "Params for soft-deleting (rejecting) a Memory at an observed version.",
        "properties": {
          "memory_id": {
            "format": "uuid7",
            "title": "Memory Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["memory_id", "version"],
        "title": "RejectParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/facet_overview",
      "name": "facet_overview",
      "params_model": "FacetOverviewParams",
      "schema": {
        "description": "Params for the Commons facet overview: distinct keys/values with counts.\n\nRead-only; takes no inputs beyond the session identity the gate already\nrequires.",
