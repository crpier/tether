      "schema": {
        "description": "Params for capturing a one-off actionable task.\n\n`condition` is an optional free-text waiting condition (\"next time I visit\nAna\") for an event-triggered task that resists a fixed date; omit it for a\ntask that is ready now. Attach a deadline trigger afterward with\n`link_todo_trigger`.",
        "properties": {
          "action": {
            "title": "Action",
            "type": "string"
          },
          "condition": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Condition"
          }
        },
        "required": ["action"],
        "title": "CreateTodoParams",
        "type": "object"
      }
    },
    {
