    {
      "endpoint": "/internal/tools/propose",
      "name": "propose",
      "params_model": "ProposeParams",
      "schema": {
        "$defs": {
          "ProposeActionParam": {
            "description": "One typed action to compose into a proposal.\n\n`kind` names a registered action kind; `scope` is an optional consumer-\ndefined category string (unvalidated \u2014 a typo simply fails to match a\ngrant); `params` are the kind's params, validated against its model.\n`display` is an optional human-readable one-line summary shown in the\nProposals panel; when omitted the panel renders the kind and params.",
            "properties": {
              "kind": {
                "title": "Kind",
                "type": "string"
              },
              "scope": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Scope"
              },
              "params": {
                "additionalProperties": true,
                "default": {},
                "title": "Params",
                "type": "object"
              },
              "display": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Display"
              }
            },
            "required": ["kind"],
            "title": "ProposeActionParam",
            "type": "object"
          }
        },
        "description": "Params for composing a proposal \u2014 an explicit set of typed actions.\n\nThe proposal executes immediately only if every action is covered by an\nexisting autonomy grant; otherwise the whole set queues for human review.\nApproval, rejection, and granting are human-only and never tools.",
        "properties": {
          "consumer": {
            "title": "Consumer",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "actions": {
            "items": {
              "$ref": "#/$defs/ProposeActionParam"
            },
            "title": "Actions",
            "type": "array"
          }
        },
        "required": ["consumer", "title", "summary", "actions"],
        "title": "ProposeParams",
        "type": "object"
      }
    },
