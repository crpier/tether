{
  "tools": [
    {
      "endpoint": "/internal/tools/capture",
      "name": "capture",
      "params_model": "CaptureParams",
      "schema": {
        "$defs": {
          "MemoryContent": {
            "minLength": 1,
            "type": "string"
          }
        },
        "description": "Params for capturing a loose Memory.",
        "properties": {
          "content": {
            "$ref": "#/$defs/MemoryContent"
          }
        },
        "required": ["content"],
        "title": "CaptureParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/browse",
      "name": "browse",
      "params_model": "BrowseParams",
      "schema": {
        "$defs": {
          "MemoryState": {
            "enum": ["loose", "tethered"],
            "type": "string"
          }
        },
        "description": "Params for the review queue (`loose`) / corpus browse (`tethered`).",
        "properties": {
          "state": {
            "$ref": "#/$defs/MemoryState"
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "required": ["state"],
        "title": "BrowseParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/search",
      "name": "search",
      "params_model": "SearchParams",
      "schema": {
        "description": "Params for the assistant's keyword Search over tethered Memories.",
        "properties": {
          "q": {
            "title": "Q",
            "type": "string"
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "required": ["q"],
        "title": "SearchParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/review_digest",
      "name": "review_digest",
      "params_model": "ReviewDigestParams",
      "schema": {
        "description": "Params for the AI-assisted Review digest.\n\nThe digest is computed over the whole live queue, so it takes no inputs\nbeyond the session identity the gate already requires.",
        "properties": {},
        "title": "ReviewDigestParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/tether",
      "name": "tether",
      "params_model": "TetherParams",
      "schema": {
        "description": "Params for promoting a loose Memory to tethered.",
        "properties": {
          "memory_id": {
            "format": "uuid7",
            "title": "Memory Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["memory_id", "version"],
        "title": "TetherParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/edit",
      "name": "edit",
      "params_model": "EditParams",
      "schema": {
        "$defs": {
          "MemoryContent": {
            "minLength": 1,
            "type": "string"
          }
        },
        "description": "Params for editing a Memory's content at an observed version.",
        "properties": {
          "memory_id": {
            "format": "uuid7",
            "title": "Memory Id",
            "type": "string"
          },
          "content": {
            "$ref": "#/$defs/MemoryContent"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["memory_id", "content", "version"],
        "title": "EditParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/reject",
      "name": "reject",
      "params_model": "RejectParams",
      "schema": {
        "description": "Params for soft-deleting (rejecting) a Memory at an observed version.",
        "properties": {
          "memory_id": {
            "format": "uuid7",
            "title": "Memory Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["memory_id", "version"],
        "title": "RejectParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/add_movie",
      "name": "add_movie",
      "params_model": "AddMovieParams",
      "schema": {
        "description": "Params for Adding a `movie` Bucket item.",
        "properties": {
          "title": {
            "title": "Title",
            "type": "string"
          },
          "intent_context": {
            "title": "Intent Context",
            "type": "string"
          },
          "year": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Year"
          }
        },
        "required": ["title", "intent_context"],
        "title": "AddMovieParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/add_place",
      "name": "add_place",
      "params_model": "AddPlaceParams",
      "schema": {
        "description": "Params for Adding a `place` Bucket item.",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "intent_context": {
            "title": "Intent Context",
            "type": "string"
          },
          "location": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Location"
          }
        },
        "required": ["name", "intent_context"],
        "title": "AddPlaceParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/complete_bucket_item",
      "name": "complete_bucket_item",
      "params_model": "CompleteBucketItemParams",
      "schema": {
        "description": "Params for completing a Bucket item at an observed version.",
        "properties": {
          "bucket_item_id": {
            "format": "uuid7",
            "title": "Bucket Item Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["bucket_item_id", "version"],
        "title": "CompleteBucketItemParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/delete_bucket_item",
      "name": "delete_bucket_item",
      "params_model": "DeleteBucketItemParams",
      "schema": {
        "description": "Params for deleting a Bucket item at an observed version.",
        "properties": {
          "bucket_item_id": {
            "format": "uuid7",
            "title": "Bucket Item Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["bucket_item_id", "version"],
        "title": "DeleteBucketItemParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/search_bucket_items",
      "name": "search_bucket_items",
      "params_model": "SearchBucketItemsParams",
      "schema": {
        "description": "Params for keyword Search over active Bucket items.",
        "properties": {
          "q": {
            "title": "Q",
            "type": "string"
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "required": ["q"],
        "title": "SearchBucketItemsParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/triage_report",
      "name": "triage_report",
      "params_model": "TriageReportParams",
      "schema": {
        "description": "Params for the Triage report.\n\nThe report is computed over the whole active Bucket list, so it takes no\ninputs beyond the session identity the gate already requires.",
        "properties": {},
        "title": "TriageReportParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/browse_youtube",
      "name": "browse_youtube",
      "params_model": "BrowseYouTubeParams",
      "schema": {
        "$defs": {
          "YouTubeSource": {
            "const": "liked",
            "type": "string"
          }
        },
        "description": "Params for a topic/source-filtered browse of ingested videos.",
        "properties": {
          "topic": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Topic"
          },
          "source": {
            "anyOf": [
              {
                "$ref": "#/$defs/YouTubeSource"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "title": "BrowseYouTubeParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/search_youtube",
      "name": "search_youtube",
      "params_model": "SearchYouTubeParams",
      "schema": {
        "description": "Search saved videos by title, description, and transcript text in one pass.\n\nEach result row already carries a description (and, for transcript matches, a\nsnippet), so a single query is usually enough \u2014 prefer reading the rows over\nre-searching with reworded terms.",
        "properties": {
          "q": {
            "title": "Q",
            "type": "string"
          },
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "required": ["q"],
        "title": "SearchYouTubeParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/fetch_youtube_transcript",
      "name": "fetch_youtube_transcript",
      "params_model": "FetchYouTubeTranscriptParams",
      "schema": {
        "description": "Params for fetching and persisting a video's transcript.",
        "properties": {
          "video_id": {
            "title": "Video Id",
            "type": "string"
          }
        },
        "required": ["video_id"],
        "title": "FetchYouTubeTranscriptParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/ignore_youtube_video",
      "name": "ignore_youtube_video",
      "params_model": "IgnoreYouTubeVideoParams",
      "schema": {
        "description": "Params for purging a video from ingestion.",
        "properties": {
          "video_id": {
            "title": "Video Id",
            "type": "string"
          }
        },
        "required": ["video_id"],
        "title": "IgnoreYouTubeVideoParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/retry_youtube_video",
      "name": "retry_youtube_video",
      "params_model": "RetryYouTubeVideoParams",
      "schema": {
        "description": "Params for returning a previously purged video to ingestion.",
        "properties": {
          "video_id": {
            "title": "Video Id",
            "type": "string"
          }
        },
        "required": ["video_id"],
        "title": "RetryYouTubeVideoParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/create_trigger",
      "name": "create_trigger",
      "params_model": "CreateTriggerParams",
      "schema": {
        "$defs": {
          "TriggerActionKind": {
            "enum": ["message", "prompt"],
            "type": "string"
          },
          "TriggerRecurrence": {
            "enum": ["once", "daily", "weekly"],
            "type": "string"
          }
        },
        "description": "Params for scheduling a trigger.\n\n`once` carries an absolute `fire_at`; `daily`/`weekly` carry `timezone` and\n`time_of_day` (and a `weekday` for weekly). Mismatched fields are rejected\nas a well-formed `invalid_input` envelope, never a corrupt row.",
        "properties": {
          "recurrence": {
            "$ref": "#/$defs/TriggerRecurrence"
          },
          "action_kind": {
            "$ref": "#/$defs/TriggerActionKind"
          },
          "payload": {
            "title": "Payload",
            "type": "string"
          },
          "timezone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Timezone"
          },
          "time_of_day": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Time Of Day"
          },
          "weekday": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Weekday"
          },
          "fire_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Fire At"
          }
        },
        "required": ["recurrence", "action_kind", "payload"],
        "title": "CreateTriggerParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/list_triggers",
      "name": "list_triggers",
      "params_model": "ListTriggersParams",
      "schema": {
        "description": "Params for listing live triggers, capped at `limit` (soonest first).",
        "properties": {
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "title": "ListTriggersParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/delete_trigger",
      "name": "delete_trigger",
      "params_model": "DeleteTriggerParams",
      "schema": {
        "description": "Params for deleting a trigger at an observed version.",
        "properties": {
          "trigger_id": {
            "format": "uuid7",
            "title": "Trigger Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          }
        },
        "required": ["trigger_id", "version"],
        "title": "DeleteTriggerParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/start_recall",
      "name": "start_recall",
      "params_model": "StartRecallParams",
      "schema": {
        "description": "Params for promoting an ingested educational video into a study item.",
        "properties": {
          "video_id": {
            "title": "Video Id",
            "type": "string"
          }
        },
        "required": ["video_id"],
        "title": "StartRecallParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/list_due_recall_prompts",
      "name": "list_due_recall_prompts",
      "params_model": "ListDueRecallPromptsParams",
      "schema": {
        "description": "Params for listing outstanding recall prompts, capped at `limit`.\n\nThe due list is computed over the whole live schedule; `limit` bounds how\nmany soonest-due prompts come back so a large backlog can't flood the model.",
        "properties": {
          "limit": {
            "default": 50,
            "exclusiveMinimum": 0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "title": "ListDueRecallPromptsParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/answer_recall_prompt",
      "name": "answer_recall_prompt",
      "params_model": "AnswerRecallPromptParams",
      "schema": {
        "description": "Params for answering a recall prompt, shaped by its kind.\n\nMultiple choice sends `selected_index`; short answer sends `answer_text`.\nEssays CANNOT be answered from this tool: their grade must be confirmed by\nthe HUMAN (ADR 0004 \u2014 the model never self-certifies learning), so propose\none with `propose_essay_grade` and let the human confirm it in the web app.",
        "properties": {
          "prompt_id": {
            "format": "uuid7",
            "title": "Prompt Id",
            "type": "string"
          },
          "selected_index": {
            "anyOf": [
              {
                "minimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Selected Index"
          },
          "answer_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Answer Text"
          },
          "response_ms": {
            "minimum": 0,
            "title": "Response Ms",
            "type": "integer"
          }
        },
        "required": ["prompt_id", "response_ms"],
        "title": "AnswerRecallPromptParams",
        "type": "object"
      }
    },
    {
      "endpoint": "/internal/tools/propose_essay_grade",
      "name": "propose_essay_grade",
      "params_model": "ProposeEssayGradeParams",
      "schema": {
        "description": "Params for proposing an essay grade against the rubric.\n\nThe proposal is advisory: the human confirms or overrides it before the\nanswer is submitted (ADR 0004), through the web surface's answer route.",
        "properties": {
          "prompt_id": {
            "format": "uuid7",
            "title": "Prompt Id",
            "type": "string"
          },
          "answer_text": {
            "title": "Answer Text",
            "type": "string"
          }
        },
        "required": ["prompt_id", "answer_text"],
        "title": "ProposeEssayGradeParams",
        "type": "object"
      }
    }
  ]
}
