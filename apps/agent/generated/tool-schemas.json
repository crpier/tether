        "description": "Params for saving a Synthetic panel.\n\nA panel must be scoped by `facets` and/or a text `query`; a `vega-lite`\nrender kind must carry its `vega_lite_spec` template. A malformed spec is\nrejected as a well-formed `invalid_input` envelope, never a corrupt row.",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "facets": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Facets",
            "type": "object"
          },
          "query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Query"
          },
          "window_days": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Window Days"
          },
          "columns": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Columns",
            "type": "array"
          },
          "render_kind": {
            "$ref": "#/$defs/PanelRenderKind",
            "default": "table"
          },
          "vega_lite_spec": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Vega Lite Spec"
          },
          "position": {
            "default": 0,
            "title": "Position",
            "type": "integer"
          }
        },
        "required": ["name", "facets"],
        "title": "CreatePanelParams",
        "type": "object"
      }
