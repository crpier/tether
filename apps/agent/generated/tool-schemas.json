    },
    {
      "endpoint": "/internal/tools/merge_facet_value",
      "name": "merge_facet_value",
      "params_model": "MergeFacetValueParams",
      "schema": {
        "description": "Params for bulk-rewriting a Commons facet value across every Memory that carries it.\n\nDestructive to the old value across the whole corpus: the assistant must\nobtain the user's explicit approval in chat before calling this tool.",
