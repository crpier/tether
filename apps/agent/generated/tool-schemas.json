        "description": "Params for transitioning a Todo's status at an observed version.",
        "properties": {
          "todo_id": {
            "format": "uuid7",
            "title": "Todo Id",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "title": "Version",
            "type": "integer"
          },
