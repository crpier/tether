# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# compose loads this file into the host container.
#
# For local dev, `just bootstrap` writes this file with TETHER_APP_PASSWORD and
# TETHER_SESSION_SECRET already generated. See docs/development.md.

# --- Auth (required) --------------------------------------------------------
# App login password and the session-cookie signing secret. Generate strong
# values, e.g.  python -c "import secrets; print(secrets.token_urlsafe(32))"
TETHER_APP_PASSWORD=change-me
TETHER_SESSION_SECRET=change-me

# --- Cookies ----------------------------------------------------------------
# Secure cookies require HTTPS. Leave false for local http compose; set true on
# the VM, where Tailscale serves the app over HTTPS.
TETHER_SECURE_COOKIES=false

# --- Agent model (required for chat / scheduled-prompt triggers) ------------
# The default model id and the allowlist the UI offers. The allowlist is JSON;
# `id` is selected by `TETHER_DEFAULT_MODEL`. Provider credentials do not live
# in this file; pi reads them from ${TETHER_PI_AGENT_DIR}/auth.json.
# The allowlist MUST stay single-quoted: `just` loads this file via dotenv, and
# its parser strips embedded double quotes from an unquoted value, which would
# corrupt the JSON and crash the host at startup.
TETHER_DEFAULT_MODEL=gpt-5.5
TETHER_MODEL_ALLOWLIST='[{"display_name":"GPT-5.5","id":"gpt-5.5","model_id":"gpt-5.5","provider":"openai-codex"},{"display_name":"GPT-5.4 Mini","id":"gpt-5.4-mini","model_id":"gpt-5.4-mini","provider":"openai-codex"}]'

# --- pi provider credentials -------------------------------------------------
# Mounted into the container as /pi-agent and used as PI_CODING_AGENT_DIR. This
# directory is durable secret state: it holds auth.json (Codex OAuth tokens,
# OpenCode Go API key, etc.) and optional pi models/settings files. Keep it
# outside the repo; back it up on the deployment server.
#
# Local bootstrap:
#   mkdir -p ~/.local/share/tether/pi-agent
#   chmod 700 ~/.local/share/tether/pi-agent
#   cp ~/.pi/agent/auth.json ~/.local/share/tether/pi-agent/auth.json  # optional seed
#   chmod 600 ~/.local/share/tether/pi-agent/auth.json
# Or log in directly:
#   PI_CODING_AGENT_DIR=~/.local/share/tether/pi-agent pi
#   /login openai-codex
#   /login opencode-go
#
# Server example:
#   TETHER_PI_AGENT_DIR=/srv/tether/pi-agent
#   back up /srv/tether/pi-agent/auth.json
#
# Current image runs as root, so refreshed OAuth files may become root-owned.
TETHER_PI_AGENT_DIR=${HOME}/.local/share/tether/pi-agent

# --- YouTube ingestion (optional) -------------------------------------------
# Tether pulls your liked videos via an OAuth-backed client. Until you
# authorize, ingestion runs the in-memory fake and the background sync stays
# off — these are unset by default. To turn it on:
#   1. Install the Google clients:  uv sync --group youtube
#   2. Download a Desktop-app OAuth client JSON from the Google Cloud Console
#      and place it at TETHER_YOUTUBE_CLIENT_SECRET_PATH (default below).
#   3. Run `just youtube-auth` once to authorize and cache the token; on a
#      headless box set TETHER_YOUTUBE_OAUTH_NO_BROWSER=1 to print the URL.
# Once the token exists the sync activates on the next host start.
#
# The paths below are the defaults for a *native* run (`just dev`). Under docker
# compose these are overridden to /data/youtube/... so the token lives on the
# durable volume and survives redeploys; you authorize on a laptop and install
# the token with `just youtube-token-install` (see docs/deploy.md#youtube-ingestion).
# TETHER_YOUTUBE_CLIENT_SECRET_PATH=.tether/youtube-client-secret.json
# TETHER_YOUTUBE_TOKEN_PATH=.tether/youtube-oauth-token.json
# TETHER_YOUTUBE_OAUTH_NO_BROWSER=false
# TETHER_YOUTUBE_SYNC_ENABLED=true
# TETHER_YOUTUBE_BACKFILL_REWALK_DAYS=30
# TETHER_YOUTUBE_DRIFT_THRESHOLD=0
# TETHER_TRANSCRIPT_SYNC_ENABLED=true
# TETHER_TRANSCRIPT_PROVIDER_ORDER=supadata,library
# TETHER_TRANSCRIPT_LANGUAGES=en,ro
# TETHER_SUPADATA_API_KEY=
# TETHER_SUPADATA_BASE_URL=https://api.supadata.ai/v1
# TETHER_SUPADATA_TIMEOUT_SECONDS=30
# TETHER_SUPADATA_POLL_INTERVAL_SECONDS=2
# TETHER_SUPADATA_MAX_POLL_ATTEMPTS=10
# TETHER_SUPADATA_MODE=native
# TETHER_SUPADATA_MAX_USES=100
